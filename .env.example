# Copy this file to `.env` and fill in the values you need:
#   cp .env.example .env
#
# Every Chess.com feature works with no key at all — only the AI Play Style
# Analysis card needs ANTHROPIC_API_KEY.

# Server-side Anthropic key for the Claude proxy. Never sent to the browser.
# Leave blank to run without AI analysis (the app degrades gracefully).
ANTHROPIC_API_KEY=

# Optional: override the Claude model (e.g. claude-sonnet-5 for richer profiles).
# Defaults to claude-haiku-4-5 when unset.
ANTHROPIC_MODEL=

# Optional: max tokens for the Claude reply. The analysis is one JSON object
# (two profiles + matchup + a detailed game plan); verbose models need headroom
# or the JSON gets cut off and fails to parse. Defaults to 4096.
ANTHROPIC_MAX_TOKENS=

# Optional: API port. The dev launcher auto-selects the next free port if this
# is taken, and the Vite proxy follows it. Defaults to 3001.
PORT=3001

# Optional: comma-separated list of allowed CORS origins for the API
# (e.g. https://chess-compare.example.com). Leave blank to allow any origin,
# which is fine for local dev. Scope this on a public deployment.
CORS_ORIGIN=

# Optional: Express "trust proxy" setting — MUST match your deployment topology.
# Defaults to false (direct exposure, like the provided docker-compose.yml). Set
# to 1 behind exactly one reverse proxy / load balancer / CDN so the rate limiter
# sees the real client IP. Trusting a proxy that isn't there lets clients spoof
# X-Forwarded-For and bypass the per-IP limit. Accepts: false, true, a hop count
# (1, 2, ...), or an express keyword such as "loopback".
TRUST_PROXY=false

# Optional: minimum log level — debug | info | warn | error. Defaults to info
# (use debug locally to see request logs and full error detail).
LOG_LEVEL=
